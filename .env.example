# ============================================================
# WhatsApp AI Bot — 环境变量配置模板
# 使用方法：复制本文件为 .env，然后填写各项配置
#   cp .env.example .env
# ============================================================


# ────────────────────────────────────────────────────────────
# 管理后台
# ────────────────────────────────────────────────────────────

# 管理后台登录密码（务必修改，不要使用默认值）
ADMIN_PASSWORD=changeme


# ────────────────────────────────────────────────────────────
# OpenAI / API 配置
# ────────────────────────────────────────────────────────────

# OpenAI API Key（从 WildCard 或 OpenAI 官网获取）
# 格式：sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-your-api-key-here

# API 请求地址（使用中转服务时替换此地址）
# 默认：https://api.openai.com/v1
# WildCard 中转：https://api.gptsapi.net/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 使用的模型（推荐 gpt-4-turbo，性价比高）
# 可选：gpt-4-turbo | gpt-4o | gpt-3.5-turbo
BOT_MODEL=gpt-4-turbo


# ────────────────────────────────────────────────────────────
# 机器人基础配置
# ────────────────────────────────────────────────────────────

# 机器人显示名称
BOT_NAME=Kevin

# 单次回复最大 Token 数（越大费用越高，建议 300~500）
BOT_MAX_TOKENS=500

# 回复语言（auto = 跟随对方语言自动切换）
BOT_LANGUAGE=auto


# ────────────────────────────────────────────────────────────
# 知识库配置
# ────────────────────────────────────────────────────────────

# 知识库检索返回的最大段落数（越大上下文越丰富，Token 消耗也越多）
KB_TOP_K=3
